//1680. Concatenation of Consecutive Binary Numbers
class Solution:
    def concatenatedBinary(self, n: int) -> int:
        MOD = 10**9 + 7
        result = 0
        length = 0
        
        for i in range(1, n + 1):
            # increase bit length when i is a power of 2
            if i & (i - 1) == 0:
                length += 1
            
            result = ((result << length) | i) % MOD
        
        return result
